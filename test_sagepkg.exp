#!/usr/bin/expect -f
set timeout 30
spawn ./lenovo_300e.sh qemu live
expect "root@sageos:/#"
send "sagepkg init\r"
expect {
    "error: expected procedure name" {
        send_user "\n[FAIL] Parser error still present\n"
        exit 1
    }
    "SagePkg" {
        send_user "\n[OK] SagePkg ran\n"
    }
    timeout {
        send_user "\n[FAIL] Timeout waiting for sagepkg\n"
        exit 1
    }
}
send "exit\r"
expect eof
